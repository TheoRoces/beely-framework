# --- Page d'erreur 404 ---
ErrorDocument 404 /404.html

# --- Sécurité ---
Options -Indexes
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
Header always set X-XSS-Protection "1; mode=block"
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://connect.facebook.net https://snap.licdn.com https://analytics.tiktok.com https://www.clarity.ms; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://api.baserow.io https://www.google-analytics.com https://region1.google-analytics.com; frame-src 'self' https://www.youtube.com https://player.vimeo.com; base-uri 'self'; form-action 'self'"

# --- Désactiver le cache LiteSpeed/HCDN ---
<IfModule LiteSpeed>
  CacheLookup off
  CacheDisable public /
  CacheDisable private /
</IfModule>

# --- Empêcher le cache CDN sur les fichiers statiques modifiables ---
<FilesMatch "\.(css|js|html)$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set CDN-Cache-Control "no-store"
  Header set Surrogate-Control "no-store"
</FilesMatch>

# --- Forcer HTTPS ---
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# --- Protéger les fichiers sensibles ---
# Bloquer l'accès à tous les dotfiles (.env, .deploy.env, .htaccess interne, etc.)
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# --- Protéger le dossier data/ ---
<DirectoryMatch "/data/">
  Require all denied
</DirectoryMatch>

# Rediriger les URLs avec .html vers la version propre (301)
# /docs/index.html → /docs/index
RewriteCond %{THE_REQUEST} \s/(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# --- Blog : URLs propres /blog/{slug} ---
# /blog/optimiser-seo-5-etapes → sert blog/article.html (le JS lit le slug depuis l'URL)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^blog/(.+)$ /blog/article.html [L]

# Servir le fichier .html pour les URLs propres (rewrite interne)
# /docs/index → docs/index.html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
