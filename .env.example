# .env.example — Variables d'environnement serveur
# Copier en .env et remplir les valeurs
# Ce fichier NE DOIT PAS être commité (.gitignore)

# ──── Baserow (Blog CMS) ────
# Token API read-only pour la table Articles
BASEROW_TOKEN=
BASEROW_URL=https://api.baserow.io

# ──── CORS ────
# Origine autorisée pour les proxys PHP (api/baserow.php, api/form.php)
# Laisser vide = accepte toutes les origines (dev uniquement)
SITE_ORIGIN=https://monsite.fr

# ──── Formulaires ────
# URL du webhook Make.com (générée automatiquement par "crée le formulaire")
FORM_WEBHOOK_URL=
FORM_NOTIFICATION_EMAIL=contact@monsite.fr

# ──── Make.com API ────
# Utilisé par la commande "crée le formulaire" pour créer le scénario automatiquement
# Générer un token : Make > Profil > API Token (scopes : scenarios:read, scenarios:write)
# Zone : visible dans l'URL Make (eu1, eu2, us1, us2)
# Team ID : visible dans l'URL Make : /organization/xxx/team/TEAM_ID/...
MAKE_API_KEY=
MAKE_ZONE=eu2.make.com
MAKE_TEAM_ID=
